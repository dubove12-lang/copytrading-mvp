# Hydromancer API integration
HYDROMANCER_API_KEY=your_hydromancer_api_key_here
HYDROMANCER_BASE_URL=https://api.hydromancer.xyz

# Leaderboard settings
HYDROMANCER_LEADERBOARD_WINDOW=30d
HYDROMANCER_LEADERBOARD_SORT_BY=totalPnl
HYDROMANCER_LEADERBOARD_LIMIT=50
HYDROMANCER_LEADERBOARD_MIN_TRADES=10
HYDROMANCER_LEADERBOARD_MIN_DAYS_ACTIVE=5

# Optional, only if Hydromancer requires / supports a DEX selector
# HYDROMANCER_DEX=hyperliquid
